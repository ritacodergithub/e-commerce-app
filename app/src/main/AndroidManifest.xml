<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".ShoplyApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ECommerceapp"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false" />

        <activity
            android:name=".ui.auth.SignupActivity"
            android:exported="false"
            android:parentActivityName=".ui.auth.LoginActivity" />

        <activity
            android:name=".ui.home.HomeActivity"
            android:exported="false" />

        <activity
            android:name=".ui.detail.ProductDetailActivity"
            android:exported="false"
            android:parentActivityName=".ui.home.HomeActivity" />

        <activity
            android:name=".ui.cart.CartActivity"
            android:exported="false"
            android:parentActivityName=".ui.home.HomeActivity" />

        <activity
            android:name=".ui.wishlist.WishlistActivity"
            android:exported="false"
            android:parentActivityName=".ui.home.HomeActivity" />

        <activity
            android:name=".ui.checkout.CheckoutActivity"
            android:exported="false"
            android:parentActivityName=".ui.cart.CartActivity" />

        <activity
            android:name=".ui.success.OrderSuccessActivity"
            android:exported="false" />

        <activity
            android:name=".ui.orders.OrderHistoryActivity"
            android:exported="false"
            android:parentActivityName=".ui.home.HomeActivity" />
    </application>

</manifest>